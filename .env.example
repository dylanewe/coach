# Intervals.icu
# Create API key at https://intervals.icu/settings (Developer section)
# Athlete ID is shown in your profile URL (e.g. i123456).
# When using a personal API key, set INTERVALS_ATHLETE_ID=0 to reference yourself.
INTERVALS_API_KEY=your_api_key_here
INTERVALS_ATHLETE_ID=0

# LLM provider: "ollama" (local) or "kimi" (Moonshot cloud)
LLM_PROVIDER=ollama

# For Ollama (local)
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:12b

# For Kimi / Moonshot (cloud) — uncomment and fill if using kimi
# LLM_PROVIDER=kimi
# LLM_API_KEY=your_kimi_api_key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-128k

# MongoDB
# Include credentials directly in the URI if auth is required:
#   MONGODB_URI=mongodb://user:pass@localhost:27017
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=coach

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_TO=runner@example.com
EMAIL_FROM=coach@example.com

# Scheduling
SYNC_CRON=0 23 * * *
WEEKLY_CRON=0 23 * * 6
TZ=Asia/Kuala_Lumpur

# Coach settings
HISTORY_DAYS=30
RACE_DATE=2026-12-12
